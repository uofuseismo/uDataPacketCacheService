#.rst
# FinduDataPacketCacheService
# ---------------------------
#
# Finds the UUSS data packet cache library.
#
# Imported Targets
# ^^^^^^^^^^^^^^^^
#
# ``uDataPacketCacheService_FOUND``
#   True indicates uDataPacketCacheService was found.
# ``uDataPacketCacheService::uDataPacketCacheService``
#   The data packet cache library, if found.
include(CMakeFindDependencyMacro)

find_dependency(TBB)

@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
